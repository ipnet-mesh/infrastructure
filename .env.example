# =============================================================================
# INFRASTRUCTURE SETTINGS
# =============================================================================
# These settings apply to the Traefik reverse proxy and shared MQTT broker.

# Root domain name
ROOT_DOMAIN=meshcore.example.com

# Traefik Ports
# Override when running behind another proxy or in a test environment
TRAEFIK_HTTP_PORT=80
TRAEFIK_HTTPS_PORT=443
TRAEFIK_LOG_LEVEL=INFO

# =============================================================================
# TLS / ACME (Cloudflare)
# =============================================================================

DNS_PROVIDER=cloudflare
DNS_API_EMAIL=email@example.com
DNS_API_TOKEN=abc123def456ghi789
ACME_EMAIL=acme@meshcore.example.com

# =============================================================================
# MQTT BROKER (shared)
# =============================================================================
# The shared MeshCore MQTT broker connects to the proxy-net network.
# All hub instances connect to this broker as subscribers.

# MQTT WebSocket port (internal container port)
MQTT_PORT=1883

# MQTT subscriber credentials
# Used by hub collectors to authenticate with the broker
MQTT_USERNAME=mqttuser
MQTT_PASSWORD=mqttpassword

# JWT audience claim for authentication tokens
# Must match AUTH_EXPECTED_AUDIENCE on the broker
MQTT_TOKEN_AUDIENCE=mqtt.localhost
